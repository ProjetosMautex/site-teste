---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import BlogCard from '../components/BlogCard';

const posts = [
  {
    title: "1 Ano de uso da roçadeira Nakasaki, minha opinião se é boa ou não",
    excerpt: "Após bastante tempo de uso intenso roçando áreas com muito mato, a roçadeira naturalmente apresenta marcas de desgaste. Confira se vale a pena o investimento.",
    date: "18 de Abril, 2026",
    url: "/teste1",
    image: "/blog/nakasaki-review.png",
    featured: true
  }
];
---

<Layout title="Blog - AstroBun Test Site">
  <Navbar client:load />
  
  <main className="blog-page">
    <section className="blog-hero">
      <div className="container">
        <h1 className="animate-fade">Nosso <span>Blog</span></h1>
        <p className="animate-fade" style="animation-delay: 0.2s">Dicas, reviews e guias práticos sobre ferramentas e manutenção.</p>
      </div>
    </section>

    <section className="blog-content">
      <div className="container">
        <div className="posts-grid">
          {posts.map(post => (
            <BlogCard {...post} client:visible />
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div className="container footer-content">
      <p>&copy; 2026 AstroBun Test Site. Desenvolvido com Antigravity.</p>
    </div>
  </footer>

  <style>
    .blog-page {
      padding-top: 80px;
    }

    .blog-hero {
      padding: 6rem 0 4rem;
      text-align: center;
      background: radial-gradient(circle at center, rgba(99, 102, 241, 0.1) 0%, transparent 70%);
    }

    h1 {
      font-size: 4rem;
      margin-bottom: 1.5rem;
    }

    h1 span {
      background: linear-gradient(to right, var(--primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .blog-hero p {
      font-size: 1.25rem;
      color: var(--text-muted);
      max-width: 600px;
      margin: 0 auto;
    }

    .blog-content {
      padding: 4rem 0 8rem;
    }

    .posts-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }

    footer {
      padding: 4rem 0;
      border-top: 1px solid var(--glass-border);
      text-align: center;
      color: var(--text-muted);
      font-size: 0.875rem;
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 2.5rem;
      }
      
      .posts-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
